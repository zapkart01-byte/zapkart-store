# ═══════════════════════════════════════════════════
# ZAPKART STORE — Mobile App Environment Variables
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Under Expo, all variables MUST start with EXPO_PUBLIC_
# to be accessible in client-side mobile code.
# ═══════════════════════════════════════════════════

# ── Supabase (Anon Key — RLS Enforced) ──
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ── Firebase (Web SDK Client Configuration) ──
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id

# ── Backend API URL (Deployed Render URL or localhost) ──
# For Android emulator: http://10.0.2.2:3000
# For physical phone (same Wi-Fi): http://YOUR_LOCAL_IP:3000
# For production: https://zapkart-backend.onrender.com
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# ── MapTiler API Key (Free Tier Vector Maps) ──
EXPO_PUBLIC_MAPTILER_KEY=your-maptiler-key-here
